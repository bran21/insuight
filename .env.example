# Insuight Resolution Bot Environment Variables

# The private key of the wallet that deployed the predict package (holds the AdminCap).
# Can be a bech32 string (suiprivkey...) or standard base64/hex string.
# WARNING: NEVER USE A MAINNET WALLET OR COMMIT THIS TO GITHUB!
SUI_PRIVATE_KEY=suiprivkey...

# The Object ID of the Market you want the bot to resolve
MARKET_ID=0x...

# The Object ID of the AdminCap NFT for this market (received when creating the market)
ADMIN_CAP_ID=0x...
